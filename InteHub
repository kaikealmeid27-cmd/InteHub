// API Cadastro empresa
app.post('/api/cadastro/empresa', async (req, res) => {
    const { nome, email, senha, cnpj } = req.body;
    const hash = await bcrypt.hash(senha, 10);
    
    db.run("INSERT INTO empresas (nome, email, senha, cnpj) VALUES (?, ?, ?, ?)", 
        [nome, email, hash, cnpj], 
        (err) => {
            if (err) return res.send("Erro: " + err.message);
            res.redirect('/login/empresa');
        });
});

