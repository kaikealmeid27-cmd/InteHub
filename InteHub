// Ranking da vaga
app.get('/vaga/:id/ranking', (req, res) => {
    if (!req.session.empresa_id) return res.redirect('/login/empresa');
    
    db.all(`
        SELECT c.nome, c.email, t.nota, t.data,
               RANK() OVER (ORDER BY t.nota DESC) as posicao
        FROM testes t
        JOIN candidatos c ON t.candidato_id = c.id
        WHERE t.vaga_id = ?
        ORDER BY t.nota DESC
        LIMIT 10
    `, [req.params.id], (err, top10) => {
        let html = `<html><head><title>Top 10</title></head><body><h2>🏆 Top 10 Candidatos</h2><table border="1"><tr><th>Posição</th><th>Nome</th><th>Email</th><th>Nota</th></tr>`;
        
        if (top10 && top10.length > 0) {
            top10.forEach(c => {
                html += `<tr><td>#${c.posicao}</td><td>${c.nome}</td><td>${c.email}</td><td>${c.nota}%</td></tr>`;
            });
        } else {
            html += `<tr><td colspan="4">Nenhum candidato ainda</td></tr>`;
        }
        
        html += `</table><br><a href="/dashboard/empresa">Voltar</a></body></html>`;
        res.send(html);
    });
});

