// Banco de dados
const db = new sqlite3.Database('./proove.db');

// Criar tabelas
db.serialize(() => {
    // Empresas
    db.run(`CREATE TABLE IF NOT EXISTS empresas (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nome TEXT,
        email TEXT UNIQUE,
        senha TEXT,
        cnpj TEXT
    )`);
    
    // Candidatos
    db.run(`CREATE TABLE IF NOT EXISTS candidatos (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        nome TEXT,
        email TEXT UNIQUE,
        senha TEXT,
        cpf TEXT,
        nota_total REAL DEFAULT 0
    )`);
    
    // Vagas
    db.run(`CREATE TABLE IF NOT EXISTS vagas (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        empresa_id INTEGER,
        titulo TEXT,
        descricao TEXT,
        area TEXT,
        ativa INTEGER DEFAULT 1
    )`);
    
    // Testes
    db.run(`CREATE TABLE IF NOT EXISTS testes (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        candidato_id INTEGER,
        vaga_id INTEGER,
        nota REAL,
        data TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    )`);
    
    // Perguntas
    db.run(`CREATE TABLE IF NOT EXISTS perguntas (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        vaga_area TEXT,
        pergunta TEXT,
        opcao_a TEXT,
        opcao_b TEXT,
        opcao_c TEXT,
        opcao_d TEXT,
        resposta_correta TEXT
    )`);
    
    // Inserir perguntas padrão
    db.get("SELECT COUNT(*) as total FROM perguntas", (err, row) => {
        if (row && row.total === 0) {
            const perguntas = [
                ['TI', 'O que significa SQL?', 'Structured Query Language', 'Simple Query Logic', 'Standard Quality Language', 'System Query Language', 'A'],
                ['TI', 'Qual destes é um framework JavaScript?', 'Django', 'React', 'Laravel', 'Flask', 'B'],
                ['TI', 'O que é Git?', 'Linguagem de programação', 'Sistema de controle de versão', 'Banco de dados', 'Framework CSS', 'B'],
                ['TI', 'O que significa API?', 'Application Programming Interface', 'Advanced Programming Integration', 'Application Process Interface', 'Automatic Program Installation', 'A'],
                ['TI', 'Qual o slogan do React?', 'Write once, run anywhere', 'A library for building user interfaces', 'The framework for ambitious developers', 'It just works', 'B']
            ];
            
            const stmt = db.prepare("INSERT INTO perguntas (vaga_area, pergunta, opcao_a, opcao_b, opcao_c, opcao_d, resposta_correta) VALUES (?, ?, ?, ?, ?, ?, ?)");
            perguntas.forEach(p => stmt.run(p));
            stmt.finalize();
            console.log('✅ Perguntas inseridas com sucesso!');
        }
    });
});

