// Página do teste
app.get('/teste/:vagaId', (req, res) => {
    if (!req.session.candidato_id) return res.redirect('/login/candidato');
    
    db.get("SELECT area FROM vagas WHERE id = ?", [req.params.vagaId], (err, vaga) => {
        if (!vaga) return res.send("Vaga não encontrada");
        
        db.all("SELECT * FROM perguntas WHERE vaga_area = ?", [vaga.area], (err, perguntas) => {
            let html = `<html><head><title>Teste Prático</title></head><body style="padding:20px;"><h2>Responda as perguntas</h2><form action="/api/enviar-teste" method="POST"><input type="hidden" name="vaga_id" value="${req.params.vagaId}">`;
            
            perguntas.forEach((p, index) => {
                html += `
                    <div style="margin-bottom:20px;">
                        <strong>${index+1}. ${p.pergunta}</strong><br>
                        <label><input type="radio" name="respostas[${index}]" value="A" required> A) ${p.opcao_a}</label><br>
                        <label><input type="radio" name="respostas[${index}]" value="B"> B) ${p.opcao_b}</label><br>
                        <label><input type="radio" name="respostas[${index}]" value="C"> C) ${p.opcao_c}</label><br>
                        <label><input type="radio" name="respostas[${index}]" value="D"> D) ${p.opcao_d}</label>
                    </div>
                `;
            });
            
            html += `<button type="submit">Enviar Respostas</button></form></body></html>`;
            res.send(html);
        });
    });
});

// Enviar teste
app.post('/api/enviar-teste', (req, res) => {
    if (!req.session.candidato_id) return res.redirect('/login/candidato');
    
    const { vaga_id, respostas } = req.body;
    
    db.get("SELECT area FROM vagas WHERE id = ?", [vaga_id], (err, vaga) => {
        db.all("SELECT * FROM perguntas WHERE vaga_area = ?", [vaga.area], (err, perguntas) => {
            let acertos = 0;
            
            perguntas.forEach((pergunta, index) => {
                if (respostas && respostas[index] === pergunta.resposta_correta) {
                    acertos++;
                }
            });
            
            const nota = (acertos / perguntas.length) * 100;
            
            db.run("INSERT INTO testes (candidato_id, vaga_id, nota) VALUES (?, ?, ?)",
                [req.session.candidato_id, vaga_id, nota],
                () => {
                    res.send(`
                        <html><body style="text-align:center; padding:50px;">
                            <h2>Sua nota: ${nota}%</h2>
                            ${nota >= 70 ? '<p>🏆 Parabéns! Você está no ranking!</p>' : '<p>📚 Estude mais e tente novamente.</p>'}
                            <a href="/dashboard/candidatos">Ver outras vagas</a>
                        </body></html>
                    `);
                });
        });
    });
});

