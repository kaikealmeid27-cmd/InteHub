// API Login empresa
app.post('/api/login/empresa', (req, res) => {
    const { email, senha } = req.body;
    
    db.get("SELECT * FROM empresas WHERE email = ?", [email], async (err, empresa) => {
        if (err || !empresa || !(await bcrypt.compare(senha, empresa.senha))) {
            return res.send("Email ou senha inválidos");
        }
        req.session.empresa_id = empresa.id;
        req.session.empresa_nome = empresa.nome;
        res.redirect('/dashboard/empresa');
    });
});

